#!/usr/bin/env bash

# Script di avvio rapido per il Job Spark Streaming (IoMT MVP)
# Creato per la presentazione d'esame

# Default a 2 executors, ma supporta l'opzione a 1 executor passando '1' come argomento
NUM_EXECS=2
if [ "$1" == "1" ]; then
  NUM_EXECS=1
fi

echo "========================================================================="
echo "       AVVIO RAPIDO: SPARK STRUCTURED STREAMING (IoMT CLINICAL ANALYTICS) "
echo "========================================================================="
echo "Deploy Mode: YARN Client"
echo "Resources: $NUM_EXECS Executor(s), 1 Core, 1G Memory"
echo "-------------------------------------------------------------------------"

echo "Avvio del job Spark con il seguente comando:"
echo "-------------------------------------------------------------------------"
echo "spark-submit \\"
echo "  --master yarn \\"
echo "  --deploy-mode client \\"
echo "  --num-executors $NUM_EXECS \\"
echo "  --executor-cores 1 \\"
echo "  --executor-memory 1G \\"
echo "  --driver-memory 1G \\"
echo "  heart_rate_streaming_v2.py"
echo "-------------------------------------------------------------------------"

spark-submit \
  --master yarn \
  --deploy-mode client \
  --num-executors $NUM_EXECS \
  --executor-cores 1 \
  --executor-memory 1G \
  --driver-memory 1G \
  heart_rate_streaming_v2.py
